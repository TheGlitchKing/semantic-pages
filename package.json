{
  "name": "@theglitchking/semantic-pages",
  "version": "0.4.3",
  "description": "Semantic search + knowledge graph MCP server for any folder of markdown files",
  "type": "module",
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "exports": {
    ".": "./dist/core/index.js",
    "./mcp": "./dist/mcp/server.js"
  },
  "bin": {
    "semantic-pages": "bin/semantic-pages"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "semantic-search",
    "knowledge-graph",
    "markdown",
    "obsidian",
    "vector-search",
    "embeddings",
    "wikilinks",
    "claude",
    "llm",
    "ai",
    "notes",
    "vault"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "optionalDependencies": {
    "onnxruntime-node": "^1.24.3"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "onnxruntime-web": "^1.24.3",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "glob": "^13.0.6",
    "graphology": "^0.26.0",
    "graphology-library": "^0.8.0",
    "graphology-shortest-path": "^2.1.0",
    "graphology-traversal": "^0.3.1",
    "gray-matter": "^4.0.3",
    "hnswlib-node": "^3.0.0",
    "minimatch": "^10.2.5",
    "remark-parse": "^11.0.0",
    "remark-wiki-link": "^2.0.1",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@theglitchking/hit-em-with-the-docs": "latest",
    "@types/node": "^25.5.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
